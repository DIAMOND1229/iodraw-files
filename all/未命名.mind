{"root":{"data":{"id":"dk0sag4x5go0","created":1784285128595,"text":"地理选择性必修一"},"children":[{"data":{"id":"dk0saqo2d9c0","created":1784285151521,"text":"第一章：地球的运动"},"children":[{"data":{"id":"dk0scyvewyo0","created":1784285326108,"text":"第一节：地球的自转与公转"},"children":[{"data":{"id":"dk0sozz6tg00","created":1784286268883,"text":"地球的自转"},"children":[{"data":{"id":"dk0sp3dgq280","created":1784286276276,"text":"地球绕其自转轴的旋转运动，叫作地球的自转"},"children":[]},{"data":{"id":"dk0sppde5y80","created":1784286324161,"text":"地球的自转轴叫地轴，它的北端始终指向北极星附近"},"children":[]},{"data":{"id":"dk0ss4txx8g0","created":1784286514542,"text":"在北半球观察，恒星围绕北极星附近的某点作圆周运动"},"children":[]},{"data":{"id":"dk0ssumzh4g0","created":1784286570718,"text":"北半球纬度越高，北极星相对地平线的高度越高"},"children":[]},{"data":{"id":"dk0st86a4zc0","created":1784286600182,"text":"北极星"},"children":[]}]}]},{"data":{"id":"dk0sd766uzk0","created":1784285344174,"text":"第二节：地球运动的地理意义"},"children":[]}]},{"data":{"id":"dk0sax9wgo00","created":1784285165902,"text":"第二章：地表形态的塑造"},"children":[]},{"data":{"id":"dk0sblprihk0","created":1784285219104,"text":"第三章：大气的运动"},"children":[]},{"data":{"id":"dk0sbwb1qhs0","created":1784285242159,"text":"第四章：水的运动"},"children":[]},{"data":{"id":"dk0sc7854ow0","created":1784285265927,"text":"第五章：自然环境的整体性与差异性"},"children":[]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}