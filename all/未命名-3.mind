{"root":{"data":{"id":"dgwgnhp6hig0","created":1772877582266,"text":"高一地理必修二"},"children":[{"data":{"id":"dgwgnuxyl680","created":1772877611095,"text":"第一章：人口","layout":null},"children":[{"data":{"id":"dgwgshuj2080","created":1772877974410,"text":"人口分布","expandState":"expand","layout":null},"children":[{"data":{"id":"dgwgreijxeo0","created":1772877888791,"text":"世界人口分布","layout":null},"children":[{"data":{"id":"dgwgrh7i1nk0","created":1772877894653,"text":"四大稠密区：东亚、南亚、欧洲西部、北美东部","layout":null},"children":[]},{"data":{"id":"dgwgrlpwoiw0","created":1772877904473,"text":"明显稀疏区：高纬度、干旱沙漠、湿热雨林、高山高原","layout":null},"children":[]}]},{"data":{"id":"dgwgrrfuv800","created":1772877916926,"text":"影响分布的因素","layout":null},"children":[{"data":{"id":"dgwgrwp9ipk0","created":1772877928379,"text":"自然因素：气候（温和）、地形（平原）、水源、土壤、矿产资源","layout":null},"children":[]},{"data":{"id":"dgwgry7ydy00","created":1772877931686,"text":"人文因素：开发历史、经济发展水平（就业）、交通、政策","layout":null},"children":[]}]},{"data":{"id":"dgwgs62jcoo0","created":1772877948773,"text":"南半球人口较少的原因：陆地面积小，多海洋性气候（温带气候区陆地少）","layout":null},"children":[]}]},{"data":{"id":"dgwgss69tts0","created":1772877996888,"text":"人口迁移","layout":null},"children":[{"data":{"id":"dgwgsu8w8ew0","created":1772878001400,"text":"概念辨析","layout":null},"children":[{"data":{"id":"dgwgtbnn18o0","created":1772878039297,"text":"人口迁移（改变居住地，跨越行政界线，长期性）","layout":null},"children":[]},{"data":{"id":"dgwgtfg7vj40","created":1772878047555,"text":"人口流动（短期/周期性往返，如探亲、出差、旅游）","layout":null},"children":[]}]},{"data":{"id":"dgwgswl4n540","created":1772878006493,"text":"类型","layout":null},"children":[{"data":{"id":"dgwgtjnnkt40","created":1772878056712,"text":"国际迁移：永久性移民、外籍劳工、国际难民","layout":null},"children":[]},{"data":{"id":"dgwgtnfsn8g0","created":1772878064944,"text":"国内迁移：由乡村到城市（主流）、由城市到乡村（逆城市化）、开发区与重大工程建设移民","layout":null},"children":[]}]},{"data":{"id":"dgwgsxpp6xs0","created":1772878008946,"text":"推拉理论","layout":null},"children":[{"data":{"id":"dgwgtr4n5m80","created":1772878072977,"text":"推力（迁出地）：人口过剩、就业困难、自然灾害、收入低、环境恶化","layout":null},"children":[]},{"data":{"id":"dgwgttor8ls0","created":1772878078546,"text":"拉力（迁入地）：就业机会多、收入高、生活条件好、教育医疗发达、社会环境稳定","layout":null},"children":[]},{"data":{"id":"dgwgtwpyf6o0","created":1772878085149,"text":"中间阻碍：距离、交通、迁移成本、文化差异、政策限制","layout":null},"children":[]}]},{"data":{"id":"dgwgt0oi7280","created":1772878015404,"text":"影响","layout":null},"children":[{"data":{"id":"dgwgu3xb5mw0","created":1772878100831,"text":"对迁出地：缓解人地矛盾，增加外汇收入（人才外流）","layout":null},"children":[]},{"data":{"id":"dgwgu5zdagw0","created":1772878105309,"text":"对迁入地：提供劳动力，促进经济发展（增加环境压力，带来社会管理问题）","layout":null},"children":[]}]}]},{"data":{"id":"dgwgu9g2h7s0","created":1772878112849,"text":"人口容量","layout":null},"children":[{"data":{"id":"dgwgudm62g00","created":1772878121925,"text":"环境承载力：最多能养活多少人（警戒线，极限值）","layout":null},"children":[]},{"data":{"id":"dgwguqtb3a00","created":1772878150655,"text":"人口合理容量：最适合养活多少人（理想值，最适宜）","layout":null},"children":[]},{"data":{"id":"dgwguvxb0o80","created":1772878161781,"text":"影响因素","layout":null},"children":[{"data":{"id":"dgwguy24t0o0","created":1772878166426,"text":"资源丰富程度（正相关）","layout":null},"children":[]},{"data":{"id":"dgwgv13jw5s0","created":1772878173043,"text":"科技发展水平（正相关，资源利用率高）","layout":null},"children":[]},{"data":{"id":"dgwgv5ebjfc0","created":1772878182401,"text":"人均消费水平（负相关）","layout":null},"children":[]},{"data":{"id":"dgwgv9u4z600","created":1772878192064,"text":"地区开放程度（正相关）","layout":null},"children":[]}]},{"data":{"id":"dgwgvc5gdig0","created":1772878197102,"text":"估计的局限性：不确定性（未来科技未知）和相对确定性（一定时期内相对稳定）","layout":null},"children":[]}]}]},{"data":{"id":"dgwgse6i65k0","created":1772877966427,"text":"第二章：乡村和城镇","layout":null},"children":[{"data":{"id":"dgwgvry7x2o0","created":1772878231493,"text":"城乡空间结构","layout":null},"children":[{"data":{"id":"dgwgvth3mzk0","created":1772878234812,"text":"功能区","layout":null},"children":[{"data":{"id":"dgwgwfn83qo0","created":1772878283071,"text":"商业区：市中心、交通干线两侧（点状或条带状），地价最高，昼夜人口差异大","layout":null},"children":[]},{"data":{"id":"dgwgwh27c9c0","created":1772878286154,"text":"居住区：最广泛的功能区（分化出高级住宅区和低级住宅区）","layout":null},"children":[]},{"data":{"id":"dgwgwlql0e80","created":1772878296335,"text":"工业区：城市边缘、交通干线两侧（降低运费、减少污染）","layout":null},"children":[]},{"data":{"id":"dgwgwojsvmg0","created":1772878302455,"text":"其他：行政区、文化区、风景区","layout":null},"children":[]}]},{"data":{"id":"dgwgvw0nu2o0","created":1772878240348,"text":"内部空间结构模式","layout":null},"children":[{"data":{"id":"dgwgwrh8j3c0","created":1772878308831,"text":"同心圆模式","layout":null},"children":[]},{"data":{"id":"dgwgww2tlrc0","created":1772878318843,"text":"扇形模式","layout":null},"children":[]},{"data":{"id":"dgwgwypjl8w0","created":1772878324570,"text":"多核心模式","layout":null},"children":[]}]},{"data":{"id":"dgwgvz8j14o0","created":1772878247354,"text":"乡村内部空间结构","layout":null},"children":[{"data":{"id":"dgwgx2infj40","created":1772878332861,"text":"密集型、分散型、半聚集型","layout":null},"children":[]},{"data":{"id":"dgwgx5v0m9s0","created":1772878340139,"text":"土地利用方式：耕地、林地、草地、宅基地、公共服务设施","layout":null},"children":[]}]},{"data":{"id":"dgwgw2awy000","created":1772878254029,"text":"合理规划城乡关系：土地利用因地制宜，保护生态环境，保留文化特色","layout":null},"children":[]}]},{"data":{"id":"dgwgxu5vij40","created":1772878393038,"text":"城镇化"},"children":[{"data":{"id":"dgwgxxwikfk0","created":1772878401179,"text":"标志（三大指标）"},"children":[{"data":{"id":"dgwgy1nedqw0","created":1772878409335,"text":"城镇人口增加"},"children":[]},{"data":{"id":"dgwgy3w6be80","created":1772878414219,"text":"城镇人口比重上升（最重要指标）"},"children":[]},{"data":{"id":"dgwgy6d6f600","created":1772878419601,"text":"城镇用地规模扩大"},"children":[]}]},{"data":{"id":"dgwgy9zv9ls0","created":1772878427503,"text":"世界城镇化进程（S型曲线）"},"children":[{"data":{"id":"dgwgycngs5c0","created":1772878433284,"text":"初期阶段：水平低（<30%），速度慢"},"children":[]},{"data":{"id":"dgwgyfyx7d40","created":1772878440507,"text":"中期阶段：水平较高（30%-70%），速度快，出现郊区城市化"},"children":[]},{"data":{"id":"dgwgyj3u9b40","created":1772878447335,"text":"后期阶段：水平高（>70%），速度慢甚至停滞，出现逆城市化"},"children":[]}]},{"data":{"id":"dgwgymdzzg00","created":1772878454479,"text":"地区差异"},"children":[{"data":{"id":"dgwgyqsijfk0","created":1772878464064,"text":"发达国家：起步早、水平高、速度慢、进入后期阶段（甚至逆城市化）"},"children":[]},{"data":{"id":"dgwgyrp2vbk0","created":1772878466033,"text":"发展中国家：起步晚、水平低、速度快、处于中期阶段（虚假城市化/滞后城市化）"},"children":[]}]},{"data":{"id":"dgwgz00ktjk0","created":1772878484143,"text":"问题与对策"},"children":[]}]}]}]},"template":"right","theme":"fresh-blue","version":"1.4.43"}