{"root":{"data":{"id":"dgwgnhp6hig0","created":1772877582266,"text":"高一地理必修二"},"children":[{"data":{"id":"dgwgnuxyl680","created":1772877611095,"text":"第一章：人口"},"children":[{"data":{"id":"dgwgshuj2080","created":1772877974410,"text":"人口分布","expandState":"expand"},"children":[{"data":{"id":"dgwgreijxeo0","created":1772877888791,"text":"世界人口分布"},"children":[{"data":{"id":"dgwgrh7i1nk0","created":1772877894653,"text":"四大稠密区：东亚、南亚、欧洲西部、北美东部","layout_right_offset":{"x":25,"y":-1}},"children":[]},{"data":{"id":"dgwgrlpwoiw0","created":1772877904473,"text":"明显稀疏区：高纬度、干旱沙漠、湿热雨林、高山高原"},"children":[]}]},{"data":{"id":"dgwgrrfuv800","created":1772877916926,"text":"影响分布的因素"},"children":[{"data":{"id":"dgwgrwp9ipk0","created":1772877928379,"text":"自然因素：气候（温和）、地形（平原）、水源、土壤、矿产资源"},"children":[]},{"data":{"id":"dgwgry7ydy00","created":1772877931686,"text":"人文因素：开发历史、经济发展水平（就业）、交通、政策"},"children":[]}]},{"data":{"id":"dgwgs62jcoo0","created":1772877948773,"text":"南半球人口较少的原因：陆地面积小，多海洋性气候（温带气候区陆地少）"},"children":[]}]},{"data":{"id":"dgwgss69tts0","created":1772877996888,"text":"人口迁移"},"children":[{"data":{"id":"dgwgsu8w8ew0","created":1772878001400,"text":"概念辨析"},"children":[{"data":{"id":"dgwgtbnn18o0","created":1772878039297,"text":"人口迁移（改变居住地，跨越行政界线，长期性）"},"children":[]},{"data":{"id":"dgwgtfg7vj40","created":1772878047555,"text":"人口流动（短期/周期性往返，如探亲、出差、旅游）"},"children":[]}]},{"data":{"id":"dgwgswl4n540","created":1772878006493,"text":"类型"},"children":[{"data":{"id":"dgwgtjnnkt40","created":1772878056712,"text":"国际迁移：永久性移民、外籍劳工、国际难民"},"children":[]},{"data":{"id":"dgwgtnfsn8g0","created":1772878064944,"text":"国内迁移：由乡村到城市（主流）、由城市到乡村（逆城市化）、开发区与重大工程建设移民"},"children":[]}]},{"data":{"id":"dgwgsxpp6xs0","created":1772878008946,"text":"推拉理论"},"children":[{"data":{"id":"dgwgtr4n5m80","created":1772878072977,"text":"推力（迁出地）：人口过剩、就业困难、自然灾害、收入低、环境恶化"},"children":[]},{"data":{"id":"dgwgttor8ls0","created":1772878078546,"text":"拉力（迁入地）：就业机会多、收入高、生活条件好、教育医疗发达、社会环境稳定"},"children":[]},{"data":{"id":"dgwgtwpyf6o0","created":1772878085149,"text":"中间阻碍：距离、交通、迁移成本、文化差异、政策限制"},"children":[]}]},{"data":{"id":"dgwgt0oi7280","created":1772878015404,"text":"影响"},"children":[{"data":{"id":"dgwgu3xb5mw0","created":1772878100831,"text":"对迁出地：缓解人地矛盾，增加外汇收入（人才外流）"},"children":[]},{"data":{"id":"dgwgu5zdagw0","created":1772878105309,"text":"对迁入地：提供劳动力，促进经济发展（增加环境压力，带来社会管理问题）"},"children":[]}]}]},{"data":{"id":"dgwgu9g2h7s0","created":1772878112849,"text":"人口容量"},"children":[{"data":{"id":"dgwgudm62g00","created":1772878121925,"text":"环境承载力：最多能养活多少人（警戒线，极限值）"},"children":[]},{"data":{"id":"dgwguqtb3a00","created":1772878150655,"text":"人口合理容量：最适合养活多少人（理想值，最适宜）"},"children":[]},{"data":{"id":"dgwguvxb0o80","created":1772878161781,"text":"影响因素"},"children":[{"data":{"id":"dgwguy24t0o0","created":1772878166426,"text":"资源丰富程度（正相关）"},"children":[]}]}]}]},{"data":{"id":"dgwgse6i65k0","created":1772877966427,"text":"分支主题"},"children":[]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}