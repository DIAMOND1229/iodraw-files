{"root":{"data":{"id":"dgkc0q93jsw0","created":1771645794589,"text":"高中地理必修二"},"children":[{"data":{"id":"dgkc2j47d1c0","created":1771645935784,"text":"第一章 人口","layout":null},"children":[{"data":{"id":"dgkc8rnsc140","created":1771646424567,"text":"人口的变化，既受自然条件和社会经济条件的影响，\n又对自然环境和社会经济有着重大作用。当今世界存在的\n资源、环境、发展等问题，往往都与人口问题直接关联。\n历史和现实都表明，人口的变化一定要与区域资源环境承\n载力相适应，与社会经济发展相协调。","layout":null},"children":[]},{"data":{"id":"dgkc45ysor40","created":1771646063887,"text":"第一节 人口分布","layout":null},"children":[{"data":{"id":"dgkc952007c0","created":1771646453725,"text":"世界人口的分布","layout":null},"children":[{"data":{"id":"dgkcb491i2g0","created":1771646608702,"text":"人类诞生以来，经过漫长的繁衍与迁徙，如今已分布\n在地球上除南极洲以外的所有大陆上。","layout":null},"children":[]},{"data":{"id":"dgkcb61lzu80","created":1771646612606,"text":"世界上的人口分布很不均匀，\n有的地区人口稠密，有的地区则人口稀少。","layout":null},"children":[]},{"data":{"id":"dgkcbb80m200","created":1771646623877,"text":"从全球来看，近 90% 的人口居住在北半球，尤其在北\n纬 10°—50°地带最为集中。从距离海洋远近来看，60% 左\n右的人口居住在离海岸 200 千米以内的沿海地区。从海拔\n来看，近 80% 的人口居住在海拔 500 米以下的低平地区。","layout":null},"children":[]},{"data":{"id":"dgkcfm4fyps0","created":1771646961063,"text":"各大洲和地区的人口分布极不平衡，\n亚洲、非洲和拉丁美洲人口约占世界总人口的 85%。\n各国人口分布也不平衡，截至2021 年年底，世界上\n人口超过1亿的国家有中国、印度、美国、印度尼西\n亚、巴基斯坦、巴西、尼日利亚、孟加拉国、俄罗\n斯、墨西哥、日本、埃塞俄比亚、菲律宾、埃及等。","layout":null},"children":[]},{"data":{"id":"dgkcbh7ai740","created":1771646636894,"text":"世界四大人口稠密区","layout":null,"expandState":"expand"},"children":[{"data":{"id":"dgkcdb7azww0","created":1771646780563,"text":"世界古老的文明中心，人类在此聚居的历史悠久。","expandState":"expand","layout":null},"children":[{"data":{"id":"dgkcbontkvs0","created":1771646653131,"text":"东亚","layout":null},"children":[{"data":{"id":"dgkcbz4emcw0","created":1771646675902,"text":"我国东部","layout":null},"children":[]},{"data":{"id":"dgkcc1i5fxs0","created":1771646681087,"text":"朝鲜半岛","layout":null},"children":[]},{"data":{"id":"dgkcc59y80g0","created":1771646689298,"text":"日本中南部","layout":null},"children":[]},{"data":{"id":"dgkcc84aa740","created":1771646695486,"text":"...","layout":null},"children":[]}]},{"data":{"id":"dgkcbqgkdm00","created":1771646657046,"text":"南亚","layout":null},"children":[{"data":{"id":"dgkcce0r30o0","created":1771646708333,"text":"印度","layout":null},"children":[]},{"data":{"id":"dgkccfi1jaw0","created":1771646711555,"text":"巴基斯坦","layout":null},"children":[]},{"data":{"id":"dgkccgrex480","created":1771646714298,"text":"孟加拉国","layout":null},"children":[]},{"data":{"id":"dgkccjl6c340","created":1771646720452,"text":"斯里兰卡","layout":null},"children":[]},{"data":{"id":"dgkccm6f7og0","created":1771646726090,"text":"...","layout":null},"children":[]}]}]},{"data":{"id":"dgkcdlb8j140","created":1771646802568,"text":"经济发达，人口大多聚居在城市。","expandState":"expand","layout":null},"children":[{"data":{"id":"dgkcbs13nbc0","created":1771646660465,"text":"欧洲西部","layout":null},"children":[{"data":{"id":"dgkcdvjhc0g0","created":1771646824835,"text":"英国","layout":null},"children":[]},{"data":{"id":"dgkcdyo1sk80","created":1771646831641,"text":"法国","layout":null},"children":[]},{"data":{"id":"dgkcdznqrps0","created":1771646833799,"text":"德国","layout":null},"children":[]},{"data":{"id":"dgkce0ytgu00","created":1771646836646,"text":"荷兰","layout":null},"children":[]},{"data":{"id":"dgkce3bvswo0","created":1771646841789,"text":"...","layout":null},"children":[]}]},{"data":{"id":"dgkcburk1kg0","created":1771646666418,"text":"北美东部","layout":null},"children":[{"data":{"id":"dgkce7o4oo00","created":1771646851237,"text":"美国东部","layout":null},"children":[]},{"data":{"id":"dgkcebgay5s0","created":1771646859471,"text":"加拿大东南部","layout":null},"children":[]}]}]}]}]},{"data":{"id":"dgkc9msir3k0","created":1771646492333,"text":"影响人口分布的因素","layout":null},"children":[{"data":{"id":"dgkca7pswbk0","created":1771646537882,"text":"影响人口分布的因素可归纳为自然因素和人\n文因素两大类。","layout":null},"children":[]},{"data":{"id":"dgl4uvxwtiw0","created":1771727148975,"text":"自然因素","expandState":"expand","layout":null},"children":[{"data":{"id":"dgkc9tmlbr40","created":1771646507212,"text":"人类的生活和生产活动离不开自然环境。","layout":null},"children":[]},{"data":{"id":"dgl5rivlnc80","created":1771729706555,"text":"自然环境对人口分布的影响明显，其中气候、地形等自然因素对人口分布影响尤为重要","layout":null},"children":[]},{"data":{"id":"dgl5y4xc4h40","created":1771730224734,"text":"适宜","layout":null},"children":[{"data":{"id":"dgl5yahwfvk0","created":1771730236861,"text":"气候较为适宜的中、低纬度地区","layout":null},"children":[]},{"data":{"id":"dgl5zwv7pdc0","created":1771730363920,"text":"地势低平地区","layout":null},"children":[{"data":{"id":"dgl602itixs0","created":1771730376231,"text":"平原地区","layout":null},"children":[{"data":{"id":"dgl60a3jws00","created":1771730392722,"text":"华北平原","layout":null},"children":[]},{"data":{"id":"dgl60elfd540","created":1771730402510,"text":"长江中下游平原","layout":null},"children":[]},{"data":{"id":"dgl60j0h4wo0","created":1771730412127,"text":"恒河平原","layout":null},"children":[]}]}]},{"data":{"id":"dgl60uyts600","created":1771730438149,"text":"富有水源的地区","layout":null},"children":[{"data":{"id":"dgl618kq0vk0","created":1771730467771,"text":"北美五大湖地区","layout":null},"children":[]},{"data":{"id":"dgl61qzdlq80","created":1771730507839,"text":"塔里木盆地的绿洲","layout":null},"children":[]}]}]},{"data":{"id":"dgl5y6ss2zs0","created":1771730228812,"text":"不适宜","layout":null},"children":[{"data":{"id":"dgl5ybf5alc0","created":1771730238872,"text":"过于寒冷、干旱的地区","layout":null},"children":[{"data":{"id":"dgl5yopkl540","created":1771730267800,"text":"高纬度地带","layout":null},"children":[]},{"data":{"id":"dgl5yro3c8o0","created":1771730274241,"text":"干旱的沙漠，戈壁地区","layout":null},"children":[]}]},{"data":{"id":"dgl5yzxr1540","created":1771730292239,"text":"过于湿热的地区","layout":null},"children":[{"data":{"id":"dgl5z5cwas80","created":1771730304039,"text":"雨林地区","layout":null},"children":[]}]}]}]},{"data":{"id":"dgkc9vbzcrk0","created":1771646510924,"text":"人文因素","layout":null,"expandState":"expand"},"children":[{"data":{"id":"dgl647j9nag0","created":1771730700599,"text":"在自然条件的基础上，人口分布作为一种社会现象，还受社会经济条件、发展历史等人文因素的制约。","layout":null},"children":[]},{"data":{"id":"dgl66zgdp0w0","created":1771730918102,"text":"人类社会发展的不同阶段，生产力水平不同，社会生产方式不同，人口分布的特点也不同。","layout":null},"children":[]},{"data":{"id":"dgl6etzyaso0","created":1771731533138,"text":"农业社会以个体农业生产为主，人口主要分布在农业发达地区。","layout":null},"children":[]},{"data":{"id":"dgl6f0ykai80","created":1771731548292,"text":"工业社会的生产力水平得到空前发展，工业占据主导地位，工业企业集中在城镇，导致人口向城镇聚集。","layout":null},"children":[]},{"data":{"id":"dgl6f5ejqjs0","created":1771731557966,"text":"在一些工业发达的地区，形成了人口密集的城市带。","layout":null},"children":[]},{"data":{"id":"dgl68agu5pc0","created":1771731020439,"text":"人文影响因素","expandState":"expand","layout":null},"children":[{"data":{"id":"dgl67k2be8g0","created":1771730962964,"text":"经济发展水平","layout":null},"children":[{"data":{"id":"dgl691sh84g0","created":1771731079917,"text":"经济发展水平较高的地区，人口稠密","layout":null},"children":[{"data":{"id":"dgl69ck8gcw0","created":1771731103362,"text":"我国东部地区","layout":null},"children":[]},{"data":{"id":"dgl69fkgb3s0","created":1771731109905,"text":"美国东北部地区","layout":null},"children":[]},{"data":{"id":"dgl69kb5pzk0","created":1771731120227,"text":"欧洲西部地区","layout":null},"children":[]}]}]},{"data":{"id":"dgl67ldeisg0","created":1771730965811,"text":"历史因素","layout":null},"children":[{"data":{"id":"dgl6cfhzfdk0","created":1771731344849,"text":"历史较悠久的地区，人口稠密","layout":null},"children":[{"data":{"id":"dgl6cp7tg5k0","created":1771731366002,"text":"东亚，南亚的人口稠密区","layout":null},"children":[]}]}]},{"data":{"id":"dgl6czf1wio0","created":1771731388207,"text":"政治","layout":null},"children":[]},{"data":{"id":"dgl6d149u1s0","created":1771731391909,"text":"军事","layout":null},"children":[]},{"data":{"id":"dgl6d23ua7k0","created":1771731394059,"text":"文化","layout":null},"children":[]},{"data":{"id":"dgl6d3zcg3c0","created":1771731398141,"text":"...","layout":null},"children":[]}]}]},{"data":{"id":"dgl6db6ufxs0","created":1771731413832,"text":"世界人口的分布状况是自然、人文各因素综合作用的结果","layout":null},"children":[]}]}]},{"data":{"id":"dgkc49izh3s0","created":1771646071638,"text":"第二节 人口迁移","layout":null,"expandState":"expand"},"children":[{"data":{"id":"dgl6s8ryc6w0","created":1771732584041,"text":"什么是人口迁移","expandState":"expand"},"children":[{"data":{"id":"dgl6mib1qio0","created":1771732134601,"text":"我们把涉及人口居住地发生长期或永久改变的人口移动，称为人口迁移。"},"children":[]},{"data":{"id":"dgl6mq8s0c80","created":1771732151878,"text":"种类","expandState":"expand"},"children":[{"data":{"id":"dgl6qo0wqcg0","created":1771732460505,"text":"国际人口迁移"},"children":[]},{"data":{"id":"dgl6qsp28m80","created":1771732470673,"text":"国内人口迁移"},"children":[]}]},{"data":{"id":"dgl6r7qp9m00","created":1771732503424,"text":"人口机械增长","expandState":"expand"},"children":[{"data":{"id":"dgl6rcxarc00","created":1771732514707,"text":"人口迁移使得某一区域的人口数量发生变化，这种人口数量的变化称为人口机械增长。"},"children":[]},{"data":{"id":"dgl6rlrg5ko0","created":1771732533944,"text":"人口机械增长率"},"children":[{"data":{"id":"dgl6rrt55kw0","created":1771732547107,"text":"人口机械增长率：是指一定区域、一定时间内（通常为 1 年），净迁入人口占总人口的比例，又称人口净迁移率。"},"children":[]}]}]}]},{"data":{"id":"dgl6sgjl32w0","created":1771732600949,"text":"影响人口迁移的因素"},"children":[{"data":{"id":"dglci5bz63s0","created":1771748719562,"text":"推拉理论","expandState":"expand"},"children":[{"data":{"id":"dglcillfxc80","created":1771748754963,"text":"人口迁移的动力由迁出地的推力（排斥力）与迁入地的拉力（吸引力）共同构成。"},"children":[]},{"data":{"id":"dgld0zw45ls0","created":1771750196638,"text":"概念","expandState":"expand"},"children":[{"data":{"id":"dglcj3pdf140","created":1771748794383,"text":"迁出地的一种或多种不利因素所产生的推力，迫使人们迁出"},"children":[]},{"data":{"id":"dglcuuic4s00","created":1771749714736,"text":"迁入地的一种或多种有利因素所形成的拉力，促使人们迁入"},"children":[]}]},{"data":{"id":"dgld0q7ir6g0","created":1771750175560,"text":"自然因素和人文因素都有可能成为人口迁移的推力因素或拉力因素，人口迁移正是这些因素综合作用的结果。"},"children":[]}]},{"data":{"id":"dgl6t4cpe740","created":1771732652776,"text":"自然因素","expandState":"expand"},"children":[{"data":{"id":"dgq8dsx0ik00","created":1772244894423,"text":"地区之间自然环境的差异，以及自然环境的变化，对人口迁移有重要的影响。"},"children":[]},{"data":{"id":"dgq8msnt5lk0","created":1772245599144,"text":"推力"},"children":[{"data":{"id":"dgq8nbv0weo0","created":1772245640939,"text":"环境问题、自然灾害等对人口迁移产生巨大的推力。"},"children":[]}]},{"data":{"id":"dgq8my3tay80","created":1772245610995,"text":"拉力"},"children":[{"data":{"id":"dgq8n3yr9ls0","created":1772245623750,"text":"自然环境优美、气候宜人和资源丰富的地区是人们向往的定居地，对人口迁移产生巨大的拉力。"},"children":[]}]}]},{"data":{"id":"dgl6ta89m200","created":1771732665568,"text":"人文因素","expandState":"expand"},"children":[{"data":{"id":"dgq8quaabsg0","created":1772245916136,"text":"经济因素往往对人口迁移起着主导作用。"},"children":[]},{"data":{"id":"dgq8r58412w0","created":1772245939949,"text":"人们常常迁往经济发达或就业机会多的地区。"},"children":[{"data":{"id":"dgq8rp0i0wg0","created":1772245983025,"text":"美国劳动力的每小时收入大约是墨西哥的 8 倍，如此巨大的收入差异促使墨西哥大量移民流向美国。"},"children":[]}]},{"data":{"id":"dgq8s4zklfs0","created":1772246017797,"text":"政治"},"children":[]},{"data":{"id":"dgq8sa5yexk0","created":1772246029067,"text":"军事"},"children":[]},{"data":{"id":"dgq8sg0k3080","created":1772246041801,"text":"文化"},"children":[]},{"data":{"id":"dgq8spsbtyw0","created":1772246063072,"text":"..."},"children":[]}]}]},{"data":{"id":"dgl6sn0c8hk0","created":1771732615023,"text":"人口迁移的时空特点"},"children":[{"data":{"id":"dgl6tgjzq5c0","created":1771732679338,"text":"国际人口迁移","expandState":"expand"},"children":[{"data":{"id":"dgq936vdasg0","created":1772246883903,"text":"19世纪到20世纪上半叶"},"children":[{"data":{"id":"dgq93cvon3c0","created":1772246896982,"text":"经济快速发展"},"children":[{"data":{"id":"dgq93ju889s0","created":1772246912132,"text":"欧洲人口继续迁移至美洲和大洋洲等地"},"children":[]}]}]},{"data":{"id":"dgq93wr43080","created":1772246940241,"text":"第二次世界大战之后"},"children":[{"data":{"id":"dgq941wbbts0","created":1772246951440,"text":"人口从发展中国家流向发达国家"},"children":[]},{"data":{"id":"dgq94col9080","created":1772246974917,"text":"外籍工人逐渐成为国际人口迁移的主要形式。"},"children":[]},{"data":{"id":"dgq94yq2dnk0","created":1772247022896,"text":"欧洲"},"children":[{"data":{"id":"dgq952f24qw0","created":1772247030937,"text":"吸引了大量移民，由人口净迁出区变为人口净迁入区"},"children":[]}]},{"data":{"id":"dgq94zzme880","created":1772247025650,"text":"拉丁美洲"},"children":[{"data":{"id":"dgq964gc7zs0","created":1772247113733,"text":"由人口净迁入区变为净迁出区，大量人口流向经济发达的北美和欧洲"},"children":[]}]}]},{"data":{"id":"dgq98qcrg0w0","created":1772247318134,"text":"20世纪70年代以来"},"children":[{"data":{"id":"dgq98xbrjso0","created":1772247333311,"text":"西亚和北非石油输出国从境外招募了大批外籍工人，成为人口净迁入区。"},"children":[]}]},{"data":{"id":"dgq993rpvt40","created":1772247347336,"text":"近年来"},"children":[{"data":{"id":"dgq99ep2kyg0","created":1772247371121,"text":"由于战乱等原因，西亚、北非的大量难民迁往欧洲。"},"children":[]}]}]},{"data":{"id":"dgl6tivv3w00","created":1771732684409,"text":"国内人口迁移"},"children":[{"data":{"id":"dgwetp4xfu00","created":1772872426420,"text":"国内人口迁移总是以各种各样的形式频繁发生，对一个国家的人口分布影响很大。"},"children":[]},{"data":{"id":"dgweut34eyg0","created":1772872513382,"text":"工业化影响","expandState":"expand"},"children":[{"data":{"id":"dgwettn1e680","created":1772872436223,"text":"工业化以前"},"children":[{"data":{"id":"dgweubxgsio0","created":1772872476035,"text":"大规模的垦荒、严重的自然灾害、战乱等往往引发国内人口迁移潮。"},"children":[]}]},{"data":{"id":"dgweu02soyo0","created":1772872450236,"text":"工业化以后"},"children":[{"data":{"id":"dgweukvj6go0","created":1772872495509,"text":"人口从农村向城镇的迁移是最为广泛的一种国内人口迁移。"},"children":[]}]}]},{"data":{"id":"dgweus5mmjc0","created":1772872511357,"text":"在我国历史上发生过的大规模国内人口迁移"},"children":[{"data":{"id":"dgwevcj1efk0","created":1772872555704,"text":"1949 年以来，我国的国内人口迁移大致可以分为两个阶段。"},"children":[{"data":{"id":"dgwewdbftug0","created":1772872635785,"text":"改革开放以前"},"children":[{"data":{"id":"dgwexujjuzk0","created":1772872751645,"text":"国家实施计划经济体制和严格的户籍管理制度，国内人口迁移主要是有计划、有组织地进行。"},"children":[]},{"data":{"id":"dgwey8hf9bs0","created":1772872781991,"text":"其中，20世纪50年代，为了开发边疆，国家有组织移民边疆的各类人员达百万之众。"},"children":[]}]},{"data":{"id":"dgwewhbq6qo0","created":1772872644510,"text":"改革开放以后"},"children":[{"data":{"id":"dgwez4g488w0","created":1772872851570,"text":"在快速工业化和城镇化的推动下，大量农村人口向城镇迁移"},"children":[]},{"data":{"id":"dgwezcooh680","created":1772872869502,"text":"同时，沿海地区经济发展快，吸引大量内陆人口迁入。"},"children":[]}]}]}]}]}]}]},{"data":{"id":"dgkc4c8nisw0","created":1771646077544,"text":"第三节 人口容量","layout":null},"children":[{"data":{"id":"dgq9bocj0vs0","created":1772247548859,"text":"区域资源环境承载力"},"children":[{"data":{"id":"dgwf170ngxs0","created":1772873013893,"text":"概念","expandState":"expand","layout":null},"children":[{"data":{"id":"dgwf0didsoo0","created":1772872949662,"text":"区域资源环境承载力是指在保证资源合理开发利用和保护良好生态环境的前提下，区域的资源环境条件所能承载的人口数量","layout":null},"children":[]},{"data":{"id":"dgwf0txt34w0","created":1772872985423,"text":"资源、环境对人口数量的支撑能力是有限度的。这种限度可以用区域资源环境承载力来表示。","layout":null},"children":[]},{"data":{"id":"dgwf490dy6w0","created":1772873253323,"text":"区域资源环境承载力的大小受自然资源数量和质量、社会经济和科技发展水平、人均消费水平等因素的影响和制约。"},"children":[]}]},{"data":{"id":"dgq9bv9o9rk0","created":1772247563924,"text":"自然资源状况"},"children":[{"data":{"id":"dgwf4lyt0g80","created":1772873281526,"text":"人类的生存和发展在很大程度上取决于自然资源状况。"},"children":[]},{"data":{"id":"dgwfdgtq3800","created":1772873975612,"text":"分支主题"},"children":[]}]},{"data":{"id":"dgq9c0xtarc0","created":1772247576267,"text":"社会经济和科技发展水平"},"children":[]},{"data":{"id":"dgq9c8uyv680","created":1772247593509,"text":"人均消费水平"},"children":[]}]},{"data":{"id":"dgq9ce02y200","created":1772247604702,"text":"人口合理容量"},"children":[]}]},{"data":{"id":"dgkc4jed5i80","created":1771646093126,"text":"问题研究 如何看待农民工现象","layout":null},"children":[]}]},{"data":{"id":"dgkc38i28qg0","created":1771645991041,"text":"第二章 乡村和城镇","layout":null,"expandState":"expand"},"children":[{"data":{"id":"dgq9czkzvkw0","created":1772247651679,"text":"不同地域的乡村和城镇，虽因自然环境、经济活动、地\n域文化等差异而各具特色，但因地制宜、合理利用土地成为\n共同的追求。工业革命以后，城镇化逐渐成为全球的潮流，\n推动了社会、经济的发展。但是，集生产中心和消费中心于\n一体的城镇，在其快速发展过程中，也存在一些需要解决的\n问题。"},"children":[]},{"data":{"id":"dgkc4si2fj40","created":1771646112941,"text":"第一节 乡村和城镇空间结构","layout":null},"children":[]},{"data":{"id":"dgkc50vmucw0","created":1771646131176,"text":"第二节 城镇化","layout":null},"children":[]},{"data":{"id":"dgkc542n8uw0","created":1771646138130,"text":"第三节 地域文化与城乡景观","layout":null},"children":[]},{"data":{"id":"dgkc5c30a1s0","created":1771646155566,"text":"问题研究 从市中心到郊区，你选择住哪里","layout":null},"children":[]}]},{"data":{"id":"dgkc3e3eggo0","created":1771646003215,"text":"第三章 产业区位因素","layout":null},"children":[{"data":{"id":"dgkc5sqq5u00","created":1771646191829,"text":"第一节 农业区位因素及其变化","layout":null,"expandState":"expand"},"children":[]},{"data":{"id":"dgkc5yp9wg00","created":1771646204802,"text":"第二节 工业区位因素及其变化","layout":null},"children":[]},{"data":{"id":"dgkc65vq2i00","created":1771646220429,"text":"第三节 服务业区位因素及其变化","layout":null},"children":[]},{"data":{"id":"dgkc6e4gpnc0","created":1771646238373,"text":"问题研究 实体商店何去何从","layout":null},"children":[]}]},{"data":{"id":"dgkc3lrugag0","created":1771646019931,"text":"第四章 交通运输布局与区域发展","layout":null},"children":[{"data":{"id":"dgkc6mmcu600","created":1771646256868,"text":"第一节 区域发展对交通运输布局的影响","layout":null},"children":[]},{"data":{"id":"dgkc6v8hnns0","created":1771646275621,"text":"第二节 交通运输布局对区域发展的影响","layout":null},"children":[]},{"data":{"id":"dgkc73atl940","created":1771646293176,"text":"问题研究 城市交通如何疏堵","layout":null},"children":[]}]},{"data":{"id":"dgkc3ueqtpk0","created":1771646038730,"text":"第五章 环境与发展","layout":null},"children":[{"data":{"id":"dgkc7hdle5c0","created":1771646323819,"text":"第一节 人类面临的主要环境问题","layout":null},"children":[]},{"data":{"id":"dgkc7rluviw0","created":1771646346086,"text":"第二节 走向人地协调——可持续发展","layout":null},"children":[]},{"data":{"id":"dgkc80tyieo0","created":1771646366167,"text":"第三节 中国国家发展战略举例","layout":null},"children":[]},{"data":{"id":"dgkc8a441540","created":1771646386372,"text":"问题探究 低碳食品知多少","layout":null},"children":[]}]}]},"template":"default","theme":"snow","version":"1.4.43"}