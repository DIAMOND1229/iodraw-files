{"root":{"data":{"id":"dk0sag4x5go0","created":1784285128595,"text":"地理选择性必修一"},"children":[{"data":{"id":"dk0saqo2d9c0","created":1784285151521,"text":"第一章：地球的运动"},"children":[{"data":{"id":"dk0scyvewyo0","created":1784285326108,"text":"第一节：地球的自转与公转"},"children":[{"data":{"id":"dk0sozz6tg00","created":1784286268883,"text":"地球的自转"},"children":[{"data":{"id":"dk0sti66cag0","created":1784286621944,"text":"自转轴","expandState":"expand"},"children":[{"data":{"id":"dk0sp3dgq280","created":1784286276276,"text":"地球绕其自转轴的旋转运动，叫作地球的自转"},"children":[]},{"data":{"id":"dk0sppde5y80","created":1784286324161,"text":"地球的自转轴叫地轴，它的北端始终指向北极星附近"},"children":[]}]},{"data":{"id":"dk0st86a4zc0","created":1784286600182,"text":"北极星","expandState":"expand"},"children":[{"data":{"id":"dk0ss4txx8g0","created":1784286514542,"text":"在北半球观察，恒星围绕北极星附近的某点作圆周运动"},"children":[]},{"data":{"id":"dk0ssumzh4g0","created":1784286570718,"text":"北半球纬度越高，北极星相对地平线的高度越高"},"children":[]}]},{"data":{"id":"dk0svk95o4g0","created":1784286783206,"text":"方向"},"children":[{"data":{"id":"dk0svtfz46w0","created":1784286803209,"text":"地球自西向东自传"},"children":[]}]},{"data":{"id":"dk0sw373hqg0","created":1784286824440,"text":"时间"},"children":[{"data":{"id":"dk0sw4siy5c0","created":1784286827913,"text":"自转一周的时间是1日"},"children":[]},{"data":{"id":"dk0swblz1hs0","created":1784286842754,"text":"选定的参照物不同，1日的时间长度略有差别，名称也不同"},"children":[{"data":{"id":"dk0sws6569s0","created":1784286878802,"text":"如果以太阳为参照物，则1日的时间长度为24时，称为太阳日"},"children":[]},{"data":{"id":"dk0t60xpeu80","created":1784287603161,"text":"如果以遥远的恒星为参照物，则1日的时间长度为23时56分4秒，称为恒星日"},"children":[{"data":{"id":"dk0t6ppy2e80","created":1784287657111,"text":"恒星日是地球自转的真正周期"},"children":[]}]}]}]}]}]},{"data":{"id":"dk0sd766uzk0","created":1784285344174,"text":"第二节：地球运动的地理意义"},"children":[]}]},{"data":{"id":"dk0sax9wgo00","created":1784285165902,"text":"第二章：地表形态的塑造"},"children":[]},{"data":{"id":"dk0sblprihk0","created":1784285219104,"text":"第三章：大气的运动"},"children":[]},{"data":{"id":"dk0sbwb1qhs0","created":1784285242159,"text":"第四章：水的运动"},"children":[]},{"data":{"id":"dk0sc7854ow0","created":1784285265927,"text":"第五章：自然环境的整体性与差异性"},"children":[]}]},"template":"default","theme":"fresh-blue","version":"1.4.43"}